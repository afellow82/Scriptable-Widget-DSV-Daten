// Funktion Ermittlung Gesamtanzahl der Spiele
function anzahlspielegesamt(html) {
  return (html.match(/<td align="center">\d+</g) || []).length;
}


// Funktion Ermittlung höchste Spielnummer
function hoechsteSpielnummer(html) {

  let hoechste = 0;

  let treffer = html.match(/<td align="center">(\d+)</g);

  if (treffer) {
    for (let eintrag of treffer) {
      let nummer = parseInt(eintrag.match(/\d+/)[0]);

      if (nummer > hoechste) {
        hoechste = nummer;
      }
    }
  }

  return hoechste;
}

// Funktion Umrechnung String in Datum
function datumsumrechnung(datum) {
  let [day, month, year] = datum.split(".")
  let datObj = new Date(Number(year) + 2000, month - 1, day)
  return datObj;
}


// Funktion Ermittlung Tage bis Spiel
function tageBisSpiel(eintrag) {
  if (!eintrag || !eintrag.datum) return null;

  // Datum aus String holen
  let zielDatum = datumsumrechnung(eintrag.datum);

let heute = new Date();
heute.setHours(0,0,0,0);

  // Ziel-Datum auf 00:00 setzen
  zielDatum.setHours(0, 0, 0, 0);

  // Differenz in Tagen berechnen
  let diff = zielDatum.getTime() - heute.getTime();
  let tage = Math.ceil(diff / (1000 * 60 * 60 * 24));

  return tage;
}


// Tage schön ausgeben
function tageText(tage) {
  if (tage === 0) return "(heute)";
  if (tage === 1) return "(morgen)";
  if (tage < 0) return "(vorbei)";
  return "(noch " + tage + " Tage)";
}


// Funktion Ausgabe von Spieldaten
function spielausgabe(nr) {
  if (nr !== null && nr >= 0 && dsvdaten[nr]) {

    let eintrag = dsvdaten[nr];

    let tage = tageBisSpiel(eintrag);

    let text1 = widget.addText(" ▶︎ " + eintrag.heim + " - " + eintrag.gast);
    text1.font = textschriftart;  
    text1.textColor = textfarbe;

    let text2 = widget.addText(
      "     " + eintrag.datum + " " + eintrag.uhrzeit +
      " in " + eintrag.ort + " " + tageText(tage)
    );

    text2.font = textkursivschriftart;
    text2.textColor = textfarbe;

    // roter text wenn Datum in den nächsten 7 Tagen ist
    if (tage <= 7) {
      text2.textColor = Color.red();
    }
  }
}


// Funktion Liste Spiele sortieren
function sortiereDSVDaten(liste) {

  function parseDateTime(datum, uhrzeit) {
    // Datum parsen
    if (!datum) return Number.MAX_SAFE_INTEGER;
    let [day, month, year] = datum.split(".");
    let d = Number(day);
    let m = Number(month) - 1;
    let y = Number(year);
    if (y < 100) y += 2000;

    // Uhrzeit bereinigen (wirklich ALLES raus)
    let cleanZeit = (uhrzeit || "").replace(/\s/g, "");

    let h = 0;
    let min = 0;

    if (cleanZeit.length >= 5 && cleanZeit.includes(":")) {
      h = Number(cleanZeit.substring(0, 2));
      min = Number(cleanZeit.substring(3, 5));

      if (isNaN(h)) h = 0;
      if (isNaN(min)) min = 0;
    }

    return new Date(y, m, d, h, min).getTime();
  }

  liste.sort((a, b) => {
    let timeA = parseDateTime(a.datum, a.uhrzeit);
    let timeB = parseDateTime(b.datum, b.uhrzeit);

    return timeA - timeB;
  });
  return liste;

}

