// Debuglevel
let debuglevel = 1;
// 0 - keine Analyse
// 1 - Analyse Werte
// 2 - Analyse Werte und Einfärben Stacks


// Konfiguration Liga (U12 oder U14)
const liga = "U14";


// Holen der Daten von Webseite
// Webseite U12: https://dsvdaten.dsv.de/Modules/WB/League.aspx?Season=2025&LeagueID=107&Group=&LeagueKind=L
// Webseite U14: https://dsvdaten.dsv.de/Modules/WB/League.aspx?Season=2025&LeagueID=109&Group=&LeagueKind=L
let url = "https://dsvdaten.dsv.de/Modules/WB/League.aspx?Season=2025&LeagueID=107&Group=&LeagueKind=L";
if (liga == "U14") {
  url = "https://dsvdaten.dsv.de/Modules/WB/League.aspx?Season=2025&LeagueID=109&Group=&LeagueKind=L";
}
const wv = new WebView();
await wv.loadURL(url);
const html = await wv.evaluateJavaScript(`
    function run() {
        fetch("${url}")
            .then(res=>res.text())
            .then(text=>completion(text))
    }
    run()
`,true);


if (!html || html.length < 100) {
  throw new Error("HTML konnte nicht geladen werden");
}


// Widget initialisieren
let widget = new ListWidget();
widget.setPadding(10, 20, 10, 20);
let max = anzahlspielegesamt(html);

// #0 - Spieltag
// #1 - Datum
// #2 - Uhrzeit
// #3 - Heimmannschaft
// #4 - Gastmannschaft
// #5 - Spielort
// #6 - Ergebnis
const dsvdatenarray = [];
// dsvdatenarray initialisieren
for (let i=1; i < max+1; i++ ) {
  dsvdatenarray[i] = ["0","01.01.01","00:00","Heimmannschaft","Gastmannschaft","Spielort","X:X"];
}


// Daten von Seite auslesen und in dsvdatenarray schreiben
for (let i=1; i<max+1; i++ ) {
  let suchstring = "<td align='center'>" + i + "<";
  let start = html.indexOf(suchstring);
  let starta = html.indexOf("<nobr>", start);
  let endedatum = html.indexOf("</nobr>", start);
  let endem1 = html.indexOf("</td>",endedatum+56);
  
  //Spieltag
  dsvdatenarray[i][0] = i;
  
  // Datum
  dsvdatenarray[i][1] = html.substring(starta+6,endedatum).trim();
  
  // Uhrzeit
  dsvdatenarray[i][2] = html.substring(endedatum+9,endedatum+18).trim();
  
  //Heimmannschaft
  // Manchmal gibt es vor der Heimmannschaft ein Bild in der Quelle, welches übersprungen werden muss
  let test1 = html.substring(endedatum+48,endedatum+51).trim();
  if (test1 == "div") {
    let startb = html.indexOf("</div></td>",endedatum+18);
    endem1 = html.indexOf("</td>",startb+15);
    dsvdatenarray[i][3] = html.substring(startb+15,endem1).trim();
  } else {
    dsvdatenarray[i][3] = html.substring(endedatum+56,endem1).trim();
  }
  
  //Gastmannschaft
  // Manchmal gibt es vor der Gastmannschaft ein Bild in der Quelle, welches übersprungen werden muss
  let endem2 = html.indexOf("</td>",endem1+38);
  let test2 = html.substring(endem1+30,endem1+33).trim();  
  if (test2 == "div") {
    let startc = html.indexOf("</div></td>",endem1+33);
    endem2 = html.indexOf("</td>",startc+15);
    dsvdatenarray[i][4] = html.substring(startc+15,endem2).trim();
  } else {
    dsvdatenarray[i][4] = html.substring(endem1+38,endem2).trim();
  }
  
  //Spielort
  let endeo = html.indexOf("</td>",endem2+9);
  dsvdatenarray[i][5] = html.substring(endem2+9,endeo).trim();
  
  //Ergebnis
  let startd = html.indexOf(">",endeo+11);
  let endee = html.indexOf("</a>",startd);
  dsvdatenarray[i][6] = html.substring(startd+1,endee).trim();
          
  if (debuglevel > 0) {         
    console.log("-----------------");
    console.log("dsvdatenarray Nr.: " + i);
    console.log(dsvdatenarray[i][0]);
    console.log(dsvdatenarray[i][1]);
    console.log(dsvdatenarray[i][2]);
    console.log(dsvdatenarray[i][3]);
    console.log(dsvdatenarray[i][4]);
    console.log(dsvdatenarray[i][5]);
    console.log(dsvdatenarray[i][6]);
  }
}   


// Definition Schriftarten
let titelschriftart = Font.boldSystemFont(12);
let textschriftart = Font.regularSystemFont(10);
let textschriftartfett = Font.boldSystemFont(10);


// Ausgabe
// Ermittlung nächstes Spiel mit Auswahl Stuttgart
let naechstesspiel = 0;
for (let i=1; i<max+1; i++ ) {
  if ((dsvdatenarray[i][6] == "mehr...") && ((dsvdatenarray[i][3] == "Auswahl Stuttgart")||(dsvdatenarray[i][4] == "Auswahl Stuttgart"))) {
    naechstesspiel = i
    break;
  }
}

// Ermittlung übernächstes Spiel mit Auswahl Stuttgart
let uebernaechstesspiel = 0;
for (let i=naechstesspiel+1; i<max+1; i++ ) {
  if ((dsvdatenarray[i][6] == "mehr...") && ((dsvdatenarray[i][3] == "Auswahl Stuttgart")||(dsvdatenarray[i][4] == "Auswahl Stuttgart"))) {
    uebernaechstesspiel = i
    break;
  }
}

// Ermittlung überübernächstes Spiel mit Auswahl Stuttgart
let ueberuebernaechstesspiel = 0;
for (let i=uebernaechstesspiel+1; i<max+1; i++ ) {
  if ((dsvdatenarray[i][6] == "mehr...") && ((dsvdatenarray[i][3] == "Auswahl Stuttgart")||(dsvdatenarray[i][4] == "Auswahl Stuttgart"))) {
    ueberuebernaechstesspiel = i
    break;
  }
}

let titel = widget.addText(`Wasserball Liga Baden-Württemberg ${liga}`);
titel.font = titelschriftart;

// Ermittlung gespielte Spiele in Liga
let gespieltespiele = 0;
for (let i=1; i<max+1; i++ ) {
  if (dsvdatenarray[i][6] != "mehr...") {
    gespieltespiele = gespieltespiele + 1;
  }
}
let fortschrittliga = widget.addText(`(${gespieltespiele} von ${max} Spielen absolviert)`);
fortschrittliga.font = textschriftart;

widget.addSpacer();

let ueberschrift = widget.addText("Nächste Spiele Auswahl Stuttgart:");
ueberschrift.font = textschriftartfett;


let textnaechstesspiel = "FEHLER"
if (naechstesspiel != 0) {
  if (dsvdatenarray[naechstesspiel][3] == "Auswahl Stuttgart") {
    textnaechstesspiel = widget.addText(dsvdatenarray[naechstesspiel][1] + " " + dsvdatenarray[naechstesspiel][2] + " " + dsvdatenarray[naechstesspiel][4] + " [" + dsvdatenarray[naechstesspiel][5] + "]");
    textnaechstesspiel.font = textschriftart;
  }
  if (dsvdatenarray[naechstesspiel][4] == "Auswahl Stuttgart") {
    textnaechstesspiel = widget.addText(dsvdatenarray[naechstesspiel][1] + " " + dsvdatenarray[naechstesspiel][2] + " " + dsvdatenarray[naechstesspiel][3] + " [" + dsvdatenarray[naechstesspiel][5] + "]");
    textnaechstesspiel.font = textschriftart;
  }
}

let textuebernaechstesspiel = "FEHLER"
if (uebernaechstesspiel != 0) {
  if (dsvdatenarray[uebernaechstesspiel][3] == "Auswahl Stuttgart") {
    textuebernaechstesspiel = widget.addText(dsvdatenarray[uebernaechstesspiel][1] + " " + dsvdatenarray[uebernaechstesspiel][2] + " " + dsvdatenarray[uebernaechstesspiel][4] + " [" + dsvdatenarray[uebernaechstesspiel][5] + "]");
    textuebernaechstesspiel.font = textschriftart;
  }
  if (dsvdatenarray[uebernaechstesspiel][4] == "Auswahl Stuttgart") {
    textuebernaechstesspiel = widget.addText(dsvdatenarray[uebernaechstesspiel][1] + " " + dsvdatenarray[uebernaechstesspiel][2] + " " + dsvdatenarray[uebernaechstesspiel][3] + " [" + dsvdatenarray[uebernaechstesspiel][5] + "]");
    textuebernaechstesspiel.font = textschriftart;
  }
}

let textueberuebernaechstesspiel = "FEHLER"
if (ueberuebernaechstesspiel != 0) {
  if (dsvdatenarray[ueberuebernaechstesspiel][3] == "Auswahl Stuttgart") {
    textueberuebernaechstesspiel = widget.addText(dsvdatenarray[ueberuebernaechstesspiel][1] + " " + dsvdatenarray[ueberuebernaechstesspiel][2] + " " + dsvdatenarray[ueberuebernaechstesspiel][4] + " [" + dsvdatenarray[ueberuebernaechstesspiel][5] + "]");
    textueberuebernaechstesspiel.font = textschriftart;
  }
  if (dsvdatenarray[ueberuebernaechstesspiel][4] == "Auswahl Stuttgart") {
    textueberuebernaechstesspiel = widget.addText(dsvdatenarray[ueberuebernaechstesspiel][1] + " " + dsvdatenarray[ueberuebernaechstesspiel][2] + " " + dsvdatenarray[ueberuebernaechstesspiel][3] + " [" + dsvdatenarray[ueberuebernaechstesspiel][5] + "]");
    textueberuebernaechstesspiel.font = textschriftart;
  }
}

if (debuglevel > 0) {         
  console.log("-----------------");
  console.log("Nächstes Spiel: " + naechstesspiel);
  console.log("Übernächstes Spiel: " + uebernaechstesspiel);
  console.log("Überübernächstes Spiel: " + ueberuebernaechstesspiel);
  console.log("Anzahl Spiele gesamt: " + max.toString());
}

widget.addSpacer();

// Widget starten
Script.setWidget(widget);
if (!config.runsInWidget) {
  widget.presentMedium();
}
Script.complete();

// Funktion Ermittlung Gesamtanzahl der Spiele
function anzahlspielegesamt(html) {
  let max = 0;
  for (let i=0; i<100; i++ ) {
    let suchstring = "<td align='center'>" + i + "<";
    let test = html.includes(suchstring);
    if (test == true) {
      max = max + 1;
    }
  } 
  return max
}
