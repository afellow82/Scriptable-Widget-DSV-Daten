//Daten von Webseite holen
const url = "https://dsvdaten.dsv.de/Modules/WB/League.aspx?Season=2025&LeagueID=107&Group=&LeagueKind=L";
const wv = new WebView();
await wv.loadURL(url);
const html = await wv.evaluateJavaScript(`
    function run() {
        fetch("${url}")
            .then(res=>res.text())
            .then(text=>completion(text))
    }
    run()
`,true);


// Widget initialisieren
let widget = new ListWidget();
widget.setPadding(10, 5, 10, 5);
let max = anzahlspielegesamt(html);

// #1 - Spieltag
// #2 - Datum
// #3 - Heimmannschaft
// #4 - Gastmannschaft
const dsvdatenarray = [];

// dsvdatenarray initialisieren
for (let i=1; i<max+1; i++ ) {
    dsvdatenarray[i] = ["0","01.01.01","Mannschaft1","Mannschaft2"];
}


// Spieltag und Datum auslesen und in dsvdatenarray schreiben
for (let i=1; i<max+1; i++ ) {
  let suchstring = "<td align='center'>" + i + "<";
  let start = html.indexOf(suchstring);
  let starta = html.indexOf("<nobr>", start);
  let endedatum = html.indexOf("</nobr>", start);
  dsvdatenarray[i][1] = i;
  dsvdatenarray[i][2] = html.substring(starta+6,endedatum).trim();
  console.log(dsvdatenarray[i][1]);
  console.log(dsvdatenarray[i][2]);
}  



// Ausgabe
widget.addText("Anzahl Spiele gesamt: " + max.toString());
